---
/**
 * GridRipple.astro
 *
 * Transparent layer for ripple flash effect during theme toggle.
 * High z-index (above overlay) so the flash appears on top of the reveal circle.
 * Listens to 'theme-ripple' custom event from ThemeToggle to trigger animation.
 */
---

<div id="grid-ripple" aria-hidden="true"></div>

<style>
  #grid-ripple {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 45;
    overflow: hidden;
  }

  #grid-ripple > :global(div) {
    background-color: transparent;
    will-change: background-color;
  }
</style>

<script>
  import { animate } from 'animejs';

  const CELL_SIZE = window.innerWidth < 768 ? 24 : 36;

  function buildRippleGrid() {
    const container = document.getElementById('grid-ripple');
    if (!container) return;

    const W = window.innerWidth;
    const H = window.innerHeight;
    const cols = Math.ceil(W / CELL_SIZE) + 1;
    const rows = Math.ceil(H / CELL_SIZE) + 1;

    container.innerHTML = '';
    container.style.display = 'grid';
    container.style.gridTemplateColumns = `repeat(${cols}, ${CELL_SIZE}px)`;
    container.style.gridTemplateRows = `repeat(${rows}, ${CELL_SIZE}px)`;

    const frag = document.createDocumentFragment();
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const cell = document.createElement('div');
        cell.setAttribute('data-ripple-cell', '');
        frag.appendChild(cell);
      }
    }
    container.appendChild(frag);
  }

  buildRippleGrid();

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(buildRippleGrid, 150);
  });

  // Listen for ripple trigger from ThemeToggle
  window.addEventListener('theme-ripple', ((e: CustomEvent) => {
    const { x, y, nextTheme, currentTheme } = e.detail;
    const cells = document.querySelectorAll('[data-ripple-cell]');
    if (!cells.length) return;

    const isOutward = currentTheme === 'dark';
    const flashColor = isOutward ? '235,235,223' : '37,36,34';
    const isMobile = window.innerWidth < 768;

    const maxDist = Math.hypot(
      Math.max(x, window.innerWidth - x),
      Math.max(y, window.innerHeight - y)
    );

    animate(cells, {
      backgroundColor: [
        `rgba(${flashColor},0)`,
        `rgba(${flashColor},${isMobile ? 1 : 0.8})`,
        `rgba(${flashColor},0)`
      ],
      duration: isMobile ? 1800 : 1200,
      ease: 'outQuad',
      delay: (_el: Element, i: number) => {
        const el = _el as HTMLElement;
        const cr = el.getBoundingClientRect();
        const dx = cr.left + cr.width / 2 - x;
        const dy = cr.top + cr.height / 2 - y;
        const dist = Math.hypot(dx, dy);
        const factor = isMobile ? 1.2 : 0.8;
        return isOutward ? dist * factor : (maxDist - dist) * factor;
      },
    });
  }) as EventListener);
</script>
