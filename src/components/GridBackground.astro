---
/**
 * GridBackground.astro
 *
 * Transparent grid layer (lines only) as a background texture.
 * Low z-index so it gets covered by the overlay reveal effect.
 * Auto-rebuilds on window resize (debounced 150ms).
 */
---

<div id="grid-background" aria-hidden="true"></div>

<style>
  #grid-background {
    display: none;
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  #grid-background > :global(div) {
    border-right:  1px solid color-mix(in srgb, var(--color-border) 10%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 10%, transparent);
    opacity: 0;
    transform: translate(0, 0);
    transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1), opacity 1s ease-out;
  }

  #grid-background.active > :global(div) {
    opacity: 1;
    transform: translate(0, 0);
  }
</style>

<script>
  const CELL_SIZE = window.innerWidth < 768 ? 24 : 36;

  function buildGrid() {
    const container = document.getElementById('grid-background');
    if (!container) return;

    const W = window.innerWidth;
    const H = window.innerHeight;
    const cols = Math.ceil(W / CELL_SIZE) + 1;
    const rows = Math.ceil(H / CELL_SIZE) + 1;

    container.innerHTML = '';
    container.style.display = 'grid';
    container.style.gridTemplateColumns = `repeat(${cols}, ${CELL_SIZE}px)`;
    container.style.gridTemplateRows = `repeat(${rows}, ${CELL_SIZE}px)`;
    // Center grid so it doesn't shift right
    const offsetX = (cols * CELL_SIZE - W) / 2;
    const offsetY = (rows * CELL_SIZE - H) / 2;
    container.style.marginLeft = `-${offsetX}px`;
    container.style.marginTop = `-${offsetY}px`;

    const frag = document.createDocumentFragment();
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        frag.appendChild(document.createElement('div'));
      }
    }
    container.appendChild(frag);
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(buildGrid, 150);
  });

   buildGrid();

  // Show grid immediately if animation already played or not on homepage
  const container = document.getElementById('grid-background');
  const isHomePage = !!document.querySelector('#text-svg[data-is-home-page="true"]');
  if (container && (!isHomePage || sessionStorage.getItem('wingky-anim-played'))) {
    container.classList.add('active');
  }

  // Handle grid entrance animation (first homepage load only)
  window.addEventListener('grid-intro-anim', () => {
    const container = document.getElementById('grid-background');
    if (!container) return;
    if (container.classList.contains('active')) return;

    const directions = ['left', 'right', 'top', 'bottom'];
    const randomDirection = directions[Math.floor(Math.random() * directions.length)];
    let transformStart = '';

    switch (randomDirection) {
      case 'left':   transformStart = 'translateX(-100%)'; break;
      case 'right':  transformStart = 'translateX(100%)';  break;
      case 'top':    transformStart = 'translateY(-100%)'; break;
      case 'bottom': transformStart = 'translateY(100%)';  break;
    }

    const cells = container.querySelectorAll('div');
    cells.forEach(cell => {
      (cell as HTMLElement).style.transform = transformStart;
    });

    requestAnimationFrame(() => {
      container.classList.add('active');
    });
  });
</script>
