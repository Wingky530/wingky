---
/*
 * Canvas.astro
 *
 * Renders a fixed canvas element with a particle system.
 * Particles drift slowly and bounce off viewport edges.
 * Color is read dynamically from --color-primary so it responds to theme changes.
 *
 * ── Blocks ──
 * - initCanvas       Create canvas, particles, start animation loop
 * - Particle.draw    Render particle at current position
 * - Particle.update  Move particle, bounce off edges, draw
 * - animate          RAF loop: clear + update all particles
 * - themechange      Re-read --color-primary when theme toggles
 */
---
<canvas class="fixed inset-0 z-[-1]" id="canvas"></canvas>

<script>
  let currentColor = '#ebebdf';

  function getPrimaryColor(): string {
    const css = getComputedStyle(document.documentElement);
    return css.getPropertyValue('--color-primary').trim();
  }

  function hexToRgb(hex: string) {
    const h = hex.replace('#', '');
    return {
      r: parseInt(h.slice(0, 2), 16),
      g: parseInt(h.slice(2, 4), 16),
      b: parseInt(h.slice(4, 6), 16),
    };
  }

  function initCanvas() {
    const canvas = document.getElementById('canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;

    function resizeCanvas() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }

    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    currentColor = getPrimaryColor();

    class Particle {
      x: number;
      y: number;
      radius: number;
      opacity: number;
      vx: number;
      vy: number;

      constructor(x: number, y: number, radius: number, opacity: number) {
        this.x = x;
        this.y = y;
        this.radius = radius;
        this.opacity = opacity;
        this.vx = (Math.random() - 0.5) * 0.5;
        this.vy = (Math.random() - 0.5) * 0.5;
      }

      draw() {
        const c = hexToRgb(currentColor);
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${c.r},${c.g},${c.b},${this.opacity})`;
        ctx.fill();
      }

      update() {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
        if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
        this.draw();
      }
    }

    const particles: Particle[] = [];

    for (let i = 0; i < 50; i++) {
      particles.push(new Particle(
        Math.random() * canvas.width,
        Math.random() * canvas.height,
        Math.random() * 2 + 1,
        Math.random() * 0.5 + 0.2
      ));
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach(p => p.update());
      requestAnimationFrame(animate);
    }

    animate();
  }

  window.addEventListener('DOMContentLoaded', () => {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(initCanvas, { timeout: 500 });
    } else {
      setTimeout(initCanvas, 100);
    }
  });

  window.addEventListener('themechange', () => {
    currentColor = getPrimaryColor();
  });
</script>