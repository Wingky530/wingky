---
/**
 * ThemeToggle.astro
 *
 * Tombol pengganti tema (dark/light), fixed di bawah-tengah viewport.
 * Ikon: single black hole / white hole SVG, warna kebalikan dari bg.
 * Transisi ikon: shrink → expand saat toggle.
 *
 * Saat diklik:
 * 1. Overlay #theme-reveal membesar (clip-path circle) dari tombol ke luar
 *    dengan warna background tema berikutnya.
 * 2. Grid ripple flash per-sel (warna bg tema berikutnya), delay radial.
 * 3. Tema ditukar di tengah animasi (~550ms).
 * 4. Overlay di-fade setelah penuh.
 */
---
<button id="theme-toggle" aria-label="Toggle theme">
  <svg id="toggle-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
    <!-- Accretion disk (event horizon ring) -->
    <ellipse cx="12" cy="12" rx="10" ry="4" class="hole-disk" />
    <!-- Black hole core (singularity) -->
    <circle cx="12" cy="12" r="4.5" class="hole-core" />
    <!-- Gravitational lensing arcs -->
    <path d="M4 12c2-3 5-5 8-5" class="hole-arc" />
    <path d="M20 12c-2 3-5 5-8 5" class="hole-arc" />
  </svg>
</button>

<!-- Overlay untuk circle reveal -->
<div id="theme-reveal" aria-hidden="true"></div>

<style>
  #theme-toggle {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    border: none;
    background: transparent;
    border-radius: 9999px;
    padding: 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    outline: none;
    transition: transform 0.2s ease;
  }
  #theme-toggle:hover {
    transform: translateX(-50%) scale(1.15);
  }

  #toggle-icon {
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Dark mode: white hole (light, emitting) */
  :global([data-theme="dark"] .hole-disk) {
    fill: none;
    stroke: var(--color-primary);
    stroke-width: 1.2;
    opacity: 0.7;
  }
  :global([data-theme="dark"] .hole-core) {
    fill: var(--color-primary);
  }
  :global([data-theme="dark"] .hole-arc) {
    stroke: var(--color-primary);
    stroke-width: 1;
    stroke-linecap: round;
    fill: none;
    opacity: 0.5;
  }

  /* Light mode: black hole (dark, absorbing) */
  :global([data-theme="light"] .hole-disk) {
    fill: none;
    stroke: var(--color-primary);
    stroke-width: 1.2;
    opacity: 0.7;
  }
  :global([data-theme="light"] .hole-core) {
    fill: var(--color-primary);
  }
  :global([data-theme="light"] .hole-arc) {
    stroke: var(--color-primary);
    stroke-width: 1;
    stroke-linecap: round;
    fill: none;
    opacity: 0.5;
  }

  /* Overlay reveal */
  #theme-reveal {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 10;
    opacity: 0;
    will-change: clip-path, opacity;
  }
</style>

<script>
  const BG_DARK = '#252422';
  const BG_LIGHT = '#ebebdf';

  let currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
  const toggleBtn = document.getElementById('theme-toggle');
  const revealEl = document.getElementById('theme-reveal');
  const iconEl = document.getElementById('toggle-icon');
  let isAnimating = false;

  function hexToRgb(hex: string): [number, number, number] {
    const h = hex.replace('#', '');
    return [parseInt(h.slice(0, 2), 16), parseInt(h.slice(2, 4), 16), parseInt(h.slice(4, 6), 16)];
  }

  function applyTheme(newTheme: string) {
    document.documentElement.setAttribute('data-theme', newTheme);
    currentTheme = newTheme;
    localStorage.setItem('wingky-theme', newTheme);
    window.dispatchEvent(new Event('themechange'));
  }

  toggleBtn?.addEventListener('click', () => {
    if (isAnimating) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
      return;
    }

    isAnimating = true;

    const rect = toggleBtn.getBoundingClientRect();
    const x = rect.left + rect.width / 2;
    const y = rect.top + rect.height / 2;

    const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
    const nextBg = nextTheme === 'dark' ? BG_DARK : BG_LIGHT;
    const [r, g, b] = hexToRgb(nextBg);

    const maxR = Math.ceil(Math.hypot(
      Math.max(x, window.innerWidth - x),
      Math.max(y, window.innerHeight - y)
    ));

    // Icon shrink → expand
    if (iconEl) {
      iconEl.style.transform = 'scale(0)';
      setTimeout(() => {
        iconEl.style.transform = 'scale(1)';
      }, 400);
    }

    // Overlay reveal via clip-path
    if (revealEl) {
      revealEl.style.transition = 'none';
      revealEl.style.clipPath = `circle(0px at ${x}px ${y}px)`;
      revealEl.style.backgroundColor = nextBg;
      revealEl.style.opacity = '1';
      void revealEl.offsetWidth;
      revealEl.style.transition = 'clip-path 1600ms cubic-bezier(0.4, 0, 0.2, 1)';
      revealEl.style.clipPath = `circle(${maxR}px at ${x}px ${y}px)`;
    }

    // Grid ripple (dispatch to GridRipple component)
    window.dispatchEvent(new CustomEvent('theme-ripple', {
      detail: { x, y, nextTheme }
    }));

    // Swap tema dengan delay — overlay sudah menutupi saat ini
    setTimeout(() => applyTheme(nextTheme), 800);

    // Fade out overlay setelah reveal selesai — mengungkap konten berwarna baru
    setTimeout(() => {
      if (revealEl) {
        revealEl.style.transition = 'opacity 300ms ease';
        revealEl.style.opacity = '0';
        setTimeout(() => {
          revealEl.style.transition = 'none';
          revealEl.style.clipPath = 'circle(0% at 50% 100%)';
          isAnimating = false;
        }, 320);
      } else {
        isAnimating = false;
      }
    }, 1000);
  });
</script>
