---
/**
 * ThemeToggle.astro
 *
 * Theme toggle button, fixed at bottom-center of viewport.
 * Icon: black hole SVG with layered accretion disk, ring, and event horizon.
 * Icon transition: shrink → expand on toggle.
 *
 * On click:
 * 1. Outward (dark→light): overlay expands via clip-path circle from button,
 *    theme swaps behind overlay at ~600ms, overlay fades out after.
 * 2. Inward (light→dark): overlay appears full instantly, theme swaps immediately
 *    behind it, overlay shrinks to reveal new theme from outside in.
 * 3. Grid ripple dispatched via 'theme-ripple' custom event.
 *
 * ── Blocks ──
 * - applyTheme       Set data-theme, save to localStorage, dispatch themechange
 * - click handler    Orchestrate overlay reveal + ripple + theme swap
 */
---
<button id="theme-toggle" aria-label="Toggle theme">
  <svg id="toggle-icon" width="24" height="24" viewBox="0 0 120 120" fill="none">
    <defs>
      <mask id="ring-mask">
        <rect width="120" height="120" fill="white"/>
        <circle cx="60" cy="60" r="22" fill="black"/>
      </mask>
      <mask id="disk-front-mask">
        <circle cx="60" cy="60" r="21.5" fill="white"/>
      </mask>
      <mask id="disk-back-mask">
        <rect width="120" height="120" fill="white"/>
        <circle cx="60" cy="60" r="22" fill="black"/>
      </mask>
      <mask id="horizon-mask">
        <circle cx="60" cy="60" r="21.5" fill="white"/>
      </mask>
    </defs>

    <!-- Accretion Disk (back) -->
    <g id="disk-back">
      <ellipse cx="60" cy="60" rx="52" ry="7.5" transform="rotate(-35 60 60)"
        class="hole-fill" mask="url(#disk-back-mask)" />
    </g>

    <!-- Outer Ring (donat) -->
    <g id="outer-ring">
      <circle cx="60" cy="60" r="32" class="hole-fill" mask="url(#ring-mask)" />
    </g>

    <!-- Event Horizon -->
    <g id="event-horizon" mask="url(#horizon-mask)">
      <circle cx="60" cy="60" r="19.5" class="hole-stroke" stroke-width="1.4" fill="none" />
      <circle cx="60" cy="60" r="16.8" class="hole-stroke-dim" stroke-width="0.8" fill="none" />
    </g>

    <!-- Accretion Disk (front) -->
    <g id="disk-front">
      <ellipse cx="60" cy="60" rx="52" ry="7.5" transform="rotate(-35 60 60)"
        class="hole-fill" mask="url(#disk-front-mask)" />
    </g>
  </svg>
</button>

<!-- Overlay for circle reveal -->
<div id="theme-reveal" aria-hidden="true"></div>

<style>
  #theme-toggle {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    border: none;
    background: transparent;
    border-radius: 9999px;
    padding: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
    opacity: 0;
    pointer-events: none;
  }
  :global([data-scrollable="true"]) #theme-toggle {
    position: relative;
    bottom: auto;
    left: auto;
    transform: none;
    margin: 32px auto;
    opacity: 1;
    pointer-events: auto;
  }
  :global([data-scrollable="true"]) #theme-toggle:hover {
    transform: scale(1.15);
  }
  #theme-toggle:hover {
    transform: translateX(-50%) scale(1.15);
  }

  #toggle-icon {
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(.hole-fill) {
    fill: var(--color-primary);
  }
  :global(.hole-stroke) {
    stroke: var(--color-primary);
  }
  :global(.hole-stroke-dim) {
    stroke: var(--color-primary);
    opacity: 0.55;
  }

  :global(#disk-back ellipse), :global(#disk-front ellipse) {
    animation: pulse-disk 2.5s ease-in-out infinite;
  }

  @keyframes pulse-disk {
    0%, 100% { ry: 7.5; }
    50% { ry: 4; }
  }

  #theme-reveal {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    opacity: 0;
    will-change: clip-path, opacity;
  }
</style>

<script>
  const BG_DARK = '#252422';
  const BG_LIGHT = '#ebebdf';

  let currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
  const toggleBtn = document.getElementById('theme-toggle');
  const revealEl = document.getElementById('theme-reveal');
  const iconEl = document.getElementById('toggle-icon');
  let isAnimating = false;

  function applyTheme(newTheme: string) {
    document.documentElement.style.viewTransitionName = 'none';
    document.documentElement.setAttribute('data-theme', newTheme);
    currentTheme = newTheme;
    localStorage.setItem('wingky-theme', newTheme);
    window.dispatchEvent(new Event('themechange'));
    requestAnimationFrame(() => {
      document.documentElement.style.viewTransitionName = '';
    });
  }

  toggleBtn?.addEventListener('click', () => {
    if (isAnimating) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
      return;
    }

    isAnimating = true;

    const rect = toggleBtn.getBoundingClientRect();
    const x = rect.left + rect.width / 2;
    const y = rect.top + rect.height / 2;

    const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
    const origTheme = currentTheme;
    const nextBg = nextTheme === 'dark' ? BG_DARK : BG_LIGHT;
    const isOutward = currentTheme === 'dark';

    const maxR = Math.ceil(Math.hypot(
      Math.max(x, window.innerWidth - x),
      Math.max(y, window.innerHeight - y)
    )) + 100;

    // Icon shrink → expand
    if (iconEl) {
      iconEl.style.transform = 'scale(0)';
      setTimeout(() => { iconEl.style.transform = 'scale(1)'; }, 400);
    }

    // Grid ripple
    window.dispatchEvent(new CustomEvent('theme-ripple', {
      detail: { x, y, nextTheme, currentTheme: origTheme }
    }));

    if (revealEl) {
      revealEl.style.transition = 'none';
      revealEl.style.zIndex = '15';
      revealEl.style.opacity = '1';

      if (isOutward) {
        // ── OUTWARD (dark→light): overlay expand dari tombol ──
        revealEl.style.backgroundColor = nextBg;
        revealEl.style.clipPath = `circle(0px at ${x}px ${y}px)`;
        void revealEl.offsetWidth;
        revealEl.style.transition = 'clip-path 2000ms cubic-bezier(0.42, 0, 0.58, 1)';
        revealEl.style.clipPath = `circle(${maxR}px at ${x}px ${y}px)`;

        // Swap theme at 600ms — overlay already covers content area
        setTimeout(() => applyTheme(nextTheme), 600);

        // Fade out overlay shortly after swap
        setTimeout(() => {
          revealEl.style.transition = 'opacity 200ms ease';
          revealEl.style.opacity = '0';
          setTimeout(() => {
            revealEl.style.transition = 'none';
            revealEl.style.clipPath = 'circle(0% at 50% 100%)';
            isAnimating = false;
          }, 250);
        }, 700);

      } else {
        // ── INWARD (light→dark): overlay instant full, lalu shrink ──
        const currentBg = BG_LIGHT;
        revealEl.style.backgroundColor = currentBg;
        revealEl.style.clipPath = `circle(${maxR}px at ${x}px ${y}px)`;
        void revealEl.offsetWidth;

        // Swap theme immediately behind overlay (fully covered)
        setTimeout(() => applyTheme(nextTheme), 50);

        // Start shrink after micro-delay
        setTimeout(() => {
          revealEl.style.transition = 'clip-path 1600ms cubic-bezier(0.42, 0, 0.58, 1)';
          revealEl.style.clipPath = `circle(0px at ${x}px ${y}px)`;
        }, 100);

        // Overlay shrink ke 0 = otomatis hilang, reset state
        setTimeout(() => {
          revealEl.style.transition = 'none';
          revealEl.style.opacity = '0';
          revealEl.style.clipPath = 'circle(0% at 50% 100%)';
          isAnimating = false;
        }, 1750);
      }
    }
  });
</script>