---
import Canvas from '../components/Canvas.astro';
import Layout from '../layouts/Layout.astro';
import opentype from 'opentype.js';
import fs from 'node:fs';
import path from 'node:path';

const TEXT = 'wingky.';
const FS = 130;
const FSU = 130;

const fontPath = path.resolve('./public/fonts/wingky.ttf');
const fontBuffer = fs.readFileSync(fontPath);
const font = opentype.parse(fontBuffer.buffer);
const scale = FS / font.unitsPerEm;

const glyphs = TEXT.split('').map(char => {
  const glyph = font.charToGlyph(char);
  const advance = (glyph.advanceWidth ?? 0) * scale;
  const opPath = glyph.getPath(0, FSU, FS);
  const d = opPath.toPathData(3);
  return { d, advance };
});

const glyphsJson = JSON.stringify(glyphs);
---
<Layout>
  <Canvas />

  <div class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-4">
    <div class="flex flex-col items-center justify-center z-10 w-full text-center">

      <nav id="nav-links"
        style="opacity:0;transform:translateY(-20px)"
        class="mb-10 flex space-x-12 text-sm tracking-widest text-muted">
        <a href="/projects" class="hover:text-primary transition-colors duration-200">PROJECTS</a>
        <a href="/contact"  class="hover:text-primary transition-colors duration-200">CONTACT</a>
      </nav>

      <div id="title-wrapper" class="relative flex items-center justify-center select-none">
        <svg id="grid-svg"
          class="absolute left-1/2 top-1/2 transform -translate-x-1/2 -translate-y-1/2 pointer-events-none"
          style="opacity:0;overflow:visible"
          aria-hidden="true"></svg>

        <svg id="text-svg"
          data-glyphs={glyphsJson}
          class="pointer-events-none"
          style="overflow:visible;display:block"
          aria-hidden="true"></svg>

        <h1 class="sr-only">wingky.</h1>
      </div>

      <div id="desc-text"
        style="opacity:0;transform:translateY(20px)"
        class="mt-10">
        <p class="text-base md:text-lg text-muted leading-relaxed max-w-lg mx-auto">
          I'm building
          <a href="https://github.com/Wingky530/viewport"
            class="text-primary hover:underline underline-offset-4 font-medium">ViewPort</a>,
          an all-in-one web toolkit for developers.
        </p>
      </div>

    </div>
  </div>
</Layout>

<script>
  import { createTimeline } from 'animejs/timeline';
  import { stagger } from 'animejs/utils';

  window.addEventListener('DOMContentLoaded', () => {
    const textSvg = document.getElementById('text-svg') as SVGSVGElement & HTMLElement;
    const gridSvg = document.getElementById('grid-svg') as SVGSVGElement & HTMLElement;
    const glyphs: { d: string; advance: number }[] = JSON.parse(textSvg.dataset.glyphs!);
    const TEXT = 'wingky.';

    const isMobile  = window.innerWidth < 768;
    const SCALE     = isMobile ? 0.50 : 1;
    const INIT_GAP  = isMobile ? 20: 40;
    const FINAL_GAP = isMobile ? 1  : 3;
    const PAD       = 20;
    const FSU       = 130;

    // Adjusted Vertical Offset for glyphs to align with inner grid
    const GLYPH_VERTICAL_OFFSET = -10; // Adjust this value as needed

    // Compute X positions in unscaled space
    const initX: number[] = [];
    let ix = PAD / SCALE;
    glyphs.forEach((g, i) => {
      initX.push(ix);
      ix += g.advance + (i < TEXT.length - 1 ? INIT_GAP / SCALE : 0);
    });
    const initTotalWU = ix + PAD / SCALE;

    const finalX: number[] = [];
    let fx = PAD / SCALE;
    glyphs.forEach((g, i) => {
      finalX.push(fx);
      fx += g.advance + (i < TEXT.length - 1 ? FINAL_GAP / SCALE : 0);
    });
    const finalTotalWU = fx + PAD / SCALE;

    const SVG_HU = FSU * 1.4;

    const applySize = (svg: Element, wU: number) => {
      svg.setAttribute('viewBox', `0 0 ${wU} ${SVG_HU}`);
      svg.setAttribute('width',   String(Math.round(wU * SCALE)));
      svg.setAttribute('height',  String(Math.round(SVG_HU * SCALE)));
    };
    applySize(textSvg, initTotalWU);
    applySize(gridSvg, initTotalWU);

    const pathEls = glyphs.map((g, i) => {
      const el = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      el.setAttribute('d', g.d);
      el.setAttribute('fill', 'transparent');
      el.setAttribute('stroke', 'rgba(237,237,237,0.22)');
      el.setAttribute('stroke-width', '1.8');
      el.setAttribute('transform', `translate(${initX[i]}, ${GLYPH_VERTICAL_OFFSET})`);
      textSvg.appendChild(el);
      return el;
    });

    pathEls.forEach(el => {
      const len = el.getTotalLength ? el.getTotalLength() : 800;
      el.style.strokeDasharray  = String(Math.ceil(len) + 2);
      el.style.strokeDashoffset = String(Math.ceil(len) + 2);
    });

    const BT = 3, BB = SVG_HU - 3;
    const BL = PAD / SCALE, BR = initTotalWU - PAD / SCALE;
    const EXT = 40, BASELINE = FSU, XHEIGHT = BASELINE - FSU * 0.68;

    const lineSpecs: { x1:number; y1:number; x2:number; y2:number }[] = [
      { x1: BL-EXT, y1: BT,       x2: BR+EXT, y2: BT       },
      { x1: BL-EXT, y1: XHEIGHT,  x2: BR+EXT, y2: XHEIGHT  },
      { x1: BL-EXT, y1: BASELINE, x2: BR+EXT, y2: BASELINE  },
      { x1: BL-EXT, y1: BB,       x2: BR+EXT, y2: BB        },
      { x1: BL, y1: BT-EXT, x2: BL, y2: BB+EXT },
      { x1: BR, y1: BT-EXT, x2: BR, y2: BB+EXT },
      { x1: initTotalWU/2, y1: BT-EXT*0.6, x2: initTotalWU/2, y2: BB+EXT*0.6 },
    ];

    glyphs.forEach((g, i) => {
      const xStart = initX[i];
      lineSpecs.push({ x1: xStart,            y1: BT-EXT, x2: xStart,            y2: BB+EXT });
      lineSpecs.push({ x1: xStart + g.advance, y1: BT-EXT, x2: xStart + g.advance, y2: BB+EXT });
    });

    const lineEls = lineSpecs.map(s => {
      const el = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      el.setAttribute('x1', String(s.x1)); el.setAttribute('y1', String(s.y1));
      el.setAttribute('x2', String(s.x2)); el.setAttribute('y2', String(s.y2));
      el.setAttribute('stroke', 'rgba(237,237,237,0.13)');
      el.setAttribute('stroke-width', '0.8');
      el.style.opacity = '0';
      gridSvg.appendChild(el);
      return el;
    });

    const tickPts: [number,number][] = [
      [BL,BT],[BR,BT],[BL,BB],[BR,BB],
      [BL,BASELINE],[BR,BASELINE],
      [initTotalWU/2,BT],[initTotalWU/2,BB],
    ];
    const tickEls = tickPts.map(([tx,ty]) => {
      const g = document.createElementNS('http://www.w3.org/2000/svg','g');
      const sz = 7;
      ([[tx-sz,ty,tx+sz,ty],[tx,ty-sz,tx,ty+sz]] as [number,number,number,number][]).forEach(([x1,y1,x2,y2]) => {
        const l = document.createElementNS('http://www.w3.org/2000/svg','line');
        l.setAttribute('x1',String(x1)); l.setAttribute('y1',String(y1));
        l.setAttribute('x2',String(x2)); l.setAttribute('y2',String(y2));
        l.setAttribute('stroke','rgba(237,237,237,0.38)');
        l.setAttribute('stroke-width','1');
        g.appendChild(l);
      });
      g.style.opacity = '0';
      gridSvg.appendChild(g);
      return g;
    });

    // ── TIMELINE ─────────────────────────────────────────────────────
    // FIX 1: defaults dibungkus dalam object 'defaults', easing → ease
    const tl = createTimeline({ defaults: { ease: 'outExpo' }, autoplay: true });

    // FIX 2: tl.add(targets, params, position) — targets jadi arg pertama
    // FIX 3: easing → ease, nilai easeXxx → outXxx / inOutXxx / dll

    // Phase 1: grid in
    tl.add(gridSvg, { opacity: [0,1], duration: 250, ease: 'linear' });
    tl.add(lineEls, { opacity: [0,1], delay: stagger(40), duration: 350, ease: 'outCubic' }, '-=100');
    tl.add(tickEls, { opacity: [0,1], delay: stagger(35), duration: 250, ease: 'outCubic' }, '-=200');
    tl.add('body',  { duration: 200 });

    // Phase 2: stroke draw per letter
    pathEls.forEach((el, i) => {
      const len = parseFloat(el.style.strokeDasharray);
      const dur = 350 + len * 0.14;
      tl.add(el, {
        strokeDashoffset: [len, 0],
        duration: dur,
        ease: 'inOutSine'
      }, i === 0 ? '+=0' : `-=${dur * 0.52}`);
    });

    tl.add('body', { duration: 180 });

    // Phase 3a: fill each letter
    const fillStates = pathEls.map(() => ({ v: 0 }));
    pathEls.forEach((el, i) => {
      const state = fillStates[i];
      tl.add(state, {
        v: 1,
        duration: 480,
        ease: 'outCubic',
        onUpdate() {
          const p = state.v;
          el.setAttribute('fill',   `rgba(237,237,237,${p.toFixed(3)})`);
          el.setAttribute('stroke', `rgba(237,237,237,${(0.22 * (1 - p)).toFixed(3)})`);
        },
        onComplete() {
          el.setAttribute('fill', '#ededed');
          el.setAttribute('stroke', 'none');
        }
      }, i === 0 ? '+=0' : `-=${480 - 50}`);
    });


    // Phase 3b: contract spacing
    const contractState = { p: 0 };
    tl.add(contractState, {
      p: 1,
      duration: 850,
      ease: 'cubicBezier(.25,1,.5,1)',
      onUpdate() {
        const p = contractState.p;
        pathEls.forEach((el, i) => {
          const x = initX[i] + (finalX[i] - initX[i]) * p;
          el.setAttribute('transform', `translate(${x}, ${GLYPH_VERTICAL_OFFSET})`);
        });
        const wU = initTotalWU + (finalTotalWU - initTotalWU) * p;
        applySize(textSvg, wU);
      }
    }, `+=0`); // Start this animation right after Phase 3a completes

    // Phase 4: grid out, nav + desc in
    tl.add(gridSvg,      { opacity: [1,0], duration: 600, ease: 'outCubic' });
    tl.add('#nav-links', { opacity: [0,1], translateY: [-20,0], duration: 700, ease: 'outCubic' }, '-=450');
    tl.add('#desc-text', { opacity: [0,1], translateY: [20,0],  duration: 700, ease: 'outCubic' }, '-=550');
  });
</script>