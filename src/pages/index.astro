---
import Canvas from '../components/Canvas.astro';
import Layout from '../layouts/Layout.astro';
import AnimatedTitle from '../components/AnimatedTitle.astro';
---
<Layout>
  <Canvas />

  <div class="relative flex min-h-dvh flex-col items-center justify-center overflow-hidden px-4">
    <div class="flex flex-col items-center justify-center z-10 w-full text-center">

      <nav id="nav-links"
        style="opacity:0;transform:translateY(-20px)"
        class="mb-10 flex space-x-12 text-sm tracking-widest text-muted">
        <a href="/projects" class="hover:text-primary transition-colors duration-200">PROJECTS</a>
        <a href="/contact"  class="hover:text-primary transition-colors duration-200">CONTACT</a>
      </nav>

      <AnimatedTitle isHomePage={true} text="wingky." />

      <div id="desc-text"
        style="opacity:0;transform:translateY(20px)"
        class="mt-10">
        <p class="text-base md:text-lg text-muted leading-relaxed max-w-lg mx-auto">
          I'm building
          <a href="https://github.com/Wingky530/viewport"
            class="text-primary hover:underline underline-offset-4 font-medium">ViewPort</a>,
          an all-in-one web toolkit for developers.
        </p>
      </div>

    </div>
  </div>
</Layout>
