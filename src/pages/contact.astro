---
import Nav from '../components/Nav.astro';
import Canvas from '../components/Canvas.astro';
---
<Layout>
  <Canvas />
  <Nav />
  <div class="min-h-screen flex flex-col items-center justify-center px-4 py-12">
    <h1 class="text-4xl font-bold mb-8 text-center">Contact</h1>
    <div class="max-w-xl w-full text-center space-y-6">
      <div class="bg-white/20 backdrop-blur-sm rounded-xl p-8 border border-primary/20">
        <p class="text-lg mb-4">
          Let's connect! You can find me on:
        </p>
        <a href="https://github.com/Wingky530" 
           class="inline-flex items-center justify-center gap-3 bg-primary text-white px-6 py-3 rounded hover:bg-primary/90 transition-colors font-medium">
          <span>GitHub</span>
        </a>
      </div>
    </div>
  </div>
</Layout>