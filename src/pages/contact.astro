---
import Nav from '../components/Nav.astro';
import Canvas from '../components/Canvas.astro';
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <Canvas />
  <Nav />
  <div class="min-h-screen flex flex-col items-center justify-center px-4 py-24">
    <h1 class="text-4xl md:text-5xl font-bold mb-12 text-center tracking-tight">Contact</h1>
    <div class="max-w-xl w-full text-center">
      <div class="bg-black/40 backdrop-blur-md rounded-xl p-8 border border-border">
        <p class="text-lg mb-8 text-muted">
          Let's connect! You can find me on:
        </p>
        <a href="https://github.com/Wingky530" 
           class="inline-flex items-center justify-center gap-2 bg-primary text-background px-6 py-3 rounded-md hover:bg-muted transition-colors font-medium">
          <span>GitHub</span>
        </a>
      </div>
    </div>
  </div>
</Layout>