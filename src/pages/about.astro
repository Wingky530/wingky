</Layout>

<script>
  /**
   * Entry animation — stagger .ab elements, then scaleX .ab-line borders last.
   * Uses Anime.js v4 timeline. Respects prefers-reduced-motion.
   */
  import { createTimeline } from 'animejs/timeline';

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduced) {
    document.querySelectorAll('.ab').forEach(el => {
      (el as HTMLElement).style.opacity = '1';
      (el as HTMLElement).style.transform = 'none';
    });
    document.querySelectorAll('.ab-line').forEach(el => {
      (el as HTMLElement).style.transform = 'scaleX(1)';
    });
  } else {
    const tl = createTimeline({
      easing: 'easeOutExpo',
      duration: 800,
    });

    tl.add('h1.ab', {
      opacity: [0, 1],
      translateY: [40, 0],
      scale: [0.95, 1],
    }, 0);

    tl.add('section:nth-of-type(1) p.ab', {
      opacity: [0, 1],
      translateY: [20, 0],
    }, 80);

    tl.add('section:nth-of-type(2) .ab', {
      opacity: [0, 1],
      translateY: [40, 0],
      translateX: [-20, 0],
    }, 150);

    tl.add('section:nth-of-type(3) .ab', {
      opacity: [0, 1],
      translateY: [40, 0],
      translateX: [20, 0],
    }, 250);

    tl.add('section:nth-of-type(4).ab', {
      opacity: [0, 1],
      translateY: [40, 0],
    }, 350);

    tl.add('section:nth-of-type(5).ab', {
      opacity: [0, 1],
      translateY: [40, 0],
    }, 430);

    tl.add('section:nth-of-type(6).ab', {
      opacity: [0, 1],
      translateY: [40, 0],
    }, 510);

    tl.add('section:nth-of-type(7).ab', {
      opacity: [0, 1],
      translateY: [40, 0],
    }, 590);

    // Border lines animate last — scaleX from 0 to 1
    tl.add('.ab-line', {
      scaleX: [0, 1],
      duration: 600,
      easing: 'easeOutCubic',
    }, 750);
  }

  // Tech badge hover fill
  document.querySelectorAll('.tech-badge').forEach(badge => {
    const el = badge as HTMLElement;
    const bg = el.dataset.bg!;
    const img = el.querySelector('img') as HTMLImageElement | null;
    const apply = () => {
      el.style.backgroundColor = bg;
      el.style.color = '#fff';
      el.style.borderColor = bg;
      if (img) img.style.filter = 'brightness(0) invert(1)';
    };
    const reset = () => {
      el.style.backgroundColor = '';
      el.style.color = '';
      el.style.borderColor = '';
      if (img) img.style.filter = '';
    };
    el.addEventListener('pointerdown', apply);
    el.addEventListener('pointerup', reset);
    el.addEventListener('pointerleave', reset);
    el.addEventListener('mouseenter', apply);
    el.addEventListener('mouseleave', reset);
  });
</script>
