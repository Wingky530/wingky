---
import '../styles/global.css';
import GridBackground from '../components/GridBackground.astro';
import GridRipple from '../components/GridRipple.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

const { slot, scrollable } = Astro.props;
const htmlClass = scrollable
  ? 'scroll-smooth bg-background text-primary'
  : 'scroll-smooth bg-background text-primary overflow-hidden';
---
<!DOCTYPE html>
<html lang="en" data-theme="dark" class={htmlClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Wingky</title>
    <link rel="stylesheet" href="/styles/global.css" />
    <meta name="description" content="A vibe coder who actually gives a damn." />

    <meta name="google-site-verification" content="KDPX9CvEUFFnhlHd6QIa4LOCGS9WvMTU8v53IpT83rA" />

    <meta property="og:url" content="https://wingky.vercel.app/">
    <meta property="og:type" content="website">
    <meta property="og:title" content="Wingky">
    <meta property="og:description" content="A vibe coder who actually gives a damn.">
    <meta property="og:image" content="https://wingky.vercel.app/img/logo-for-metatag.jpg">

    <meta name="twitter:card" content="summary_large_image">
    <meta property="twitter:domain" content="wingky.vercel.app">
    <meta property="twitter:url" content="https://wingky.vercel.app/">
    <meta name="twitter:title" content="Wingky">
    <meta name="twitter:description" content="A vibe coder who actually gives a damn.">
    <meta name="twitter:image" content="https://wingky.vercel.app/img/logo-for-metatag.jpg">

    <script>
      (function() {
        var t = localStorage.getItem('wingky-theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <GridBackground />
    <GridRipple />
    <slot />
    <ThemeToggle />
  </body>
</html>