---
/**
 * Layout.astro
 *
 * Base HTML shell for all pages. Sets up <head> meta (SEO, OG, Twitter),
 * canonical URL, favicons, and inline theme-restore script to prevent FOUC.
 * Body includes GridRipple and ThemeToggle as persistent global layers.
 *
 * ── Props ──
 * - title, description, keywords, image   SEO meta content
 * - scrollable   When false, locks viewport overflow (landing page)
 */
import '../styles/global.css';
import GridRipple from '../components/GridRipple.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  scrollable?: boolean;
}

const {
  scrollable,
  title = 'Wingky',
  description = 'A vibe coder who actually gives a damn.',
  keywords = 'wingky, portfolio, vibe coder, web developer, motion design, frontend',
  image = 'https://wingky.vercel.app/img/logo-for-metatag.jpg',
} = Astro.props;
const htmlClass = scrollable
  ? 'scroll-smooth bg-background text-primary'
  : 'scroll-smooth bg-background text-primary overflow-hidden';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image;
const ogImageWidth = '1200';
const ogImageHeight = '630';
---
<!DOCTYPE html>
<html lang="en" data-theme="dark" class={htmlClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Wingky" />
    <meta name="theme-color" content="#252422" />
    <link rel="canonical" href={canonicalURL.href} />

    <link rel="icon" href="/img/favicon.ico" sizes="any" />
    <link rel="icon" href="/img/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/img/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/img/apple-touch-icon.png" />
    <link rel="manifest" href="/img/site.webmanifest" />

    <meta name="google-site-verification" content="KDPX9CvEUFFnhlHd6QIa4LOCGS9WvMTU8v53IpT83rA" />

    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Wingky" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={ogImageHeight} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="wingky.vercel.app" />
    <meta property="twitter:url" content={canonicalURL.href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@wingky530" />

    <script>
      (function() {
        var t = localStorage.getItem('wingky-theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body data-scrollable={scrollable ? "true" : undefined}>
    <GridRipple />
    <slot />
    <ThemeToggle />
  </body>
</html>
